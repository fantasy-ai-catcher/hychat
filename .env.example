SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
STOCK_PROVIDER=yahoo_finance
STOCK_QUOTE_CACHE_TTL_SECONDS=60

# Stock quotes use Yahoo Finance's keyless endpoint, so no provider API key is
# required. The Edge Function only needs the standard Supabase secrets
# (SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY), which the Edge
# runtime injects automatically.
